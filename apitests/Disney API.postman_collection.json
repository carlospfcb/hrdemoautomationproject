    {
      "name": "FilterByTVShows",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Iterate all the response and check tvShow = \"Jake and the Never Land Pirates\"\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const json = pm.response.json();\r",
              "\r",
              "// Read the videogame sent in the URL\r",
              "const url = new URL(pm.request.url.toString());\r",
              "const tvShowSent = url.searchParams.get(\"tvShows\");\r",
              "\r",
              "pm.test(\"All characters match the TV show filter\", function () {\r",
              "    json.data.forEach(character => {\r",
              "        pm.expect(character).to.have.property(\"tvShows\");\r",
              "        pm.expect(character.tvShows).to.be.an(\"array\");\r",
              "        pm.expect(character.tvShows).to.include(tvShowSent);\r",
              "    });\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://api.disneyapi.dev/character?tvShows=Jake and the Never Land Pirates",
