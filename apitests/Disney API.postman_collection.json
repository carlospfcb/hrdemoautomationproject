  "item": [
    {
      "name": "GetAllCharacters",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Status code\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Body is valid JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "//Response structure\r",
              "pm.test(\"Response has correct structure\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json).to.have.property('info');\r",
              "    pm.expect(json).to.have.property('data');\r",
              "\r",
              "    pm.expect(json.info).to.have.property('count');\r",
              "    pm.expect(json.info).to.have.property('totalPages');\r",
              "    pm.expect(json.info).to.have.property('nextPage');\r",
              "    pm.expect(json.info).to.have.property('previousPage');\r",
              "});\r",
              "\r",
              "pm.test(\"Info fields have correct types\", function () {\r",
              "    const info = pm.response.json().info;\r",
              "    pm.expect(info.count).to.be.a('number');\r",
              "    pm.expect(info.totalPages).to.be.a('number');\r",
              "});\r",
              "//Pagination behavior \r",
              "let json = pm.response.json();\r",
              "pm.environment.set(\"nextPage\", json.nextPage);\r",
              "\r",
              "pm.test(\"Pagination moves to different data\", function () {\r",
              "    const json = pm.response.json();\r",
              "    pm.expect(json.previousPage).to.not.be.null;\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://api.disneyapi.dev/character",
          "protocol": "https",
          "host": [
            "api",
            "disneyapi",
            "dev"
          ],
          "path": [
            "character"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GetAllCharacters Invalid Endpoint",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//Response must be 404\r",
              "pm.test(\"Status code is 404\", function () {\r",
              "    pm.response.to.have.status(404);\r",
              "});\r",
              "\r",
              "//Returns HTML (not best pratice, it should be JSON)\r",
              "pm.test(\"Response is HTML\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\"))\r",
              "      .to.include(\"text/html\");\r",
              "});\r",
              "\r",
              "pm.test(\"Error message is correct\", function () {\r",
              "    pm.expect(pm.response.text())\r",
              "      .to.include(\"Cannot GET /characterssss\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://api.disneyapi.dev/characterssss?page=1&pageSize=2",
          "protocol": "https",
          "host": [
            "api",
