    {
      "name": "GetAllCharacters nonexistent page",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();\r",
              "const url = new URL(pm.request.url.toString());\r",
              "const pageSent = parseInt(url.searchParams.get(\"page\"));\r",
              "\r",
              "//Verify data is empty\r",
              "pm.test(\"Verify empty data\", function () {\r",
              "    pm.expect(json.data.length).to.equal(0);\r",
              "});\r",
              "\r",
              "//Verify pagination sent is greater than total pages (it should fail)\r",
              "pm.test(\"Detect pagination inconsistency\", function () {\r",
              "    pm.expect(pageSent).to.be.greaterThan(json.info.totalPages);\r",
              "    pm.expect(json.info.previousPage).to.be.null; \r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
